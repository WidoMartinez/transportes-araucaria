# Configuración de Base de Datos MySQL (Hostinger)
DB_HOST=srv1551.hstgr.io
DB_PORT=3306
DB_NAME=u419311572_araucaria
DB_USER=u419311572_admin
DB_PASSWORD=TeamoGadiel7.

# Configuración de Flow
FLOW_API_KEY=tu_api_key_aqui
FLOW_SECRET_KEY=tu_secret_key_aqui
FLOW_API_URL=https://www.flow.cl/api

# URLs del sistema
BACKEND_URL=https://tu-backend-url.com
FRONTEND_URL=https://transportesaraucaria.cl

# Token de administrador para proteger rutas administrativas
# IMPORTANTE: Cambiar este valor por uno seguro y único
# Debe coincidir con VITE_ADMIN_TOKEN en el frontend
ADMIN_TOKEN=cambia-este-token-por-uno-seguro-xyz123

# Puerto del servidor
PORT=3001

# Keep-Alive para Render.com (tier gratuito)
# Evita que el servidor "duerma" después de 15 min de inactividad.
# Valor: la URL pública completa del backend en Render.
# Ejemplo: https://mi-backend.onrender.com
# El sistema hará GET /health automáticamente cada RENDER_KEEP_ALIVE_INTERVAL_MS ms.
RENDER_KEEP_ALIVE_URL=https://tu-backend.onrender.com
RENDER_KEEP_ALIVE_INTERVAL_MS=300000

# Cloudinary - Almacenamiento persistente de imágenes (banners de promociones)
# Render tiene filesystem efímero: las imágenes deben guardarse en Cloudinary
# Obtener credenciales en: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
